{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "outDir": "./dist",
    "rootDir": "./",
    "removeComments": true,
    "preserveConstEnums": true
  },
  "include": [
    "*.ts",
    "./*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
